# Enable the browser fallback (uses the `browse` CLI) for Cloudflare-protected
# gtaweb.eu endpoints. Set to 0 to disable and degrade gracefully.
BROWSE_FALLBACK=1

# Path to the `browse` CLI binary (default: resolved from PATH).
# BROWSE_BIN=/Users/you/.bun/bin/browse

# Override the User-Agent used for plain HTTP fetches.
# GTA_MCP_USER_AGENT=Mozilla/5.0 ...
